generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  avatar        String?
  phone         String?
  referralCount Int      @default(0)
  isVip         Boolean  @default(false)
  createdAt     DateTime @default(now())

  memberships GroupMember[]
  activity    ActivityMessage[]
}

model Product {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  description   String?
  emoji         String   @default("🛍️")
  category      String
  badge         String?
  badgeColor    String?
  basePrice     Float
  currentPrice  Float
  originalPrice Float
  targetBuyers  Int      @default(50)
  endTime       DateTime
  rating        Float    @default(4.5)
  reviews       Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  tiers    Tier[]
  groups   Group[]
  activity ActivityMessage[]
}

model Tier {
  id                   String  @id @default(cuid())
  productId            String
  requiredParticipants Int
  priceAtTier          Float

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, requiredParticipants])
}

model Group {
  id        String   @id @default(cuid())
  productId String   @unique
  createdAt DateTime @default(now())

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  members GroupMember[]
}

model GroupMember {
  id         String   @id @default(cuid())
  groupId    String
  userId     String
  referredBy String?  // userId of whoever shared the invite link
  joinedAt   DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

// ── Activity Feed ──────────────────────────────────────────────────────────────
// Stores both user chat messages and system events (joins, price drops, referrals)
model ActivityMessage {
  id        String   @id @default(cuid())
  productId String
  userId    String?  // null for system-generated messages
  userName  String
  content   String
  type      String   @default("chat")  // "chat" | "join" | "referral" | "milestone"
  emoji     String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
}
